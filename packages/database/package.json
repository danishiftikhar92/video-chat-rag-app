{
  "name": "@video-rag/database",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migration:run": "tsc -p tsconfig.json && node dist/run-migrations.js",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/typeorm": "^10.0.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
