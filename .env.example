NODE_ENV=development
PORT=3000
WEB_PORT=5173
WORKER_CONCURRENCY=2
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/video_rag
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173

STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./uploads
AUDIO_TEMP_DIR=./uploads/tmp

TRANSCRIPTION_PROVIDER=whispercpp
WHISPER_BIN_PATH=whisper-cli
WHISPER_MODEL_PATH=./models/ggml-base.bin

CHAT_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Chat LLM gateway (local Ollama by default)
LLM_PROVIDER=ollama
LLM_DEFAULT_MODEL=llama3.2:1b
LLM_AVAILABLE_MODELS=llama3.2:1b,qwen2.5:1.5b,smollm2:1.7b,gemma2:2b,phi3:mini

OLLAMA_BASE_URL=http://localhost:11434
# Kept for backward compatibility; defaults to LLM_DEFAULT_MODEL when unset
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=all-minilm
EMBEDDING_DIMENSIONS=384

# Optional OpenAI-compatible online models (registered when API key is set)
LLM_OPENAI_BASE_URL=
LLM_OPENAI_API_KEY=
LLM_OPENAI_MODELS=

TYPEORM_SYNC=true
MAX_UPLOAD_SIZE_MB=512

ALLOWED_SOURCE_HOSTS=youtube.com,www.youtube.com,youtu.be
MAX_VIDEO_DURATION_SECONDS=21600
MAX_DOWNLOAD_SIZE_MB=512
INGESTION_RATE_LIMIT=10
CHAT_RATE_LIMIT=60

# Langfuse observability (optional — tracing no-ops when unset/disabled)
# Get keys from https://cloud.langfuse.com or your self-hosted instance
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Leave empty for Langfuse Cloud; set for self-hosted (e.g. http://localhost:3001)
LANGFUSE_BASE_URL=
# true | false | empty (auto-enable when both keys are set)
LANGFUSE_ENABLED=
# Overrides NODE_ENV mapping (development | staging | prod)
OBSERVABILITY_ENVIRONMENT=
